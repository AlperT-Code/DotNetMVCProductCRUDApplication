@model IEnumerable<DotNetCrudApp.Models.Product>

<div class="card shadow-lg border-0 rounded-lg">
    <div class="card-header bg-gradient text-white py-3 d-flex justify-content-between align-items-center" 
         style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <h3 class="mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Ürün Listesi
        </h3>
        <a class="btn btn-light" href="/Products/Create">
            <i class="bi bi-plus-circle me-1"></i>Yeni Ürün Ekle
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h4 class="text-muted mt-3">Ürün bulunamadı</h4>
                <p class="text-muted">Yeni ürün eklemek için "Yeni Ürün Ekle" butonuna tıklayın.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Ürün Adı</th>
                            <th>Fiyat</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.Id</td>
                                <td>@item.Name</td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2">
                                        <i class="bi bi-currency-dollar me-1"></i>@item.Price.ToString("C2")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Products/Edit/@item.Id" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil me-1"></i>Düzenle
                                    </a>
                                    <a href="#" class="btn btn-sm btn-danger delete-btn" data-id="@item.Id">
                                        <i class="bi bi-trash me-1"></i>Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>