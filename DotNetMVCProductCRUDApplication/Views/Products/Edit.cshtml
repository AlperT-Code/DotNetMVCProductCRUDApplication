@model DotNetCrudApp.Models.Product

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-lg">
            <div class="card-header bg-gradient text-white py-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <h3 class="mb-0 text-center">
                    <i class="bi bi-pencil-square me-2"></i>
                    Ürün Güncelle
                </h3>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">
                            <i class="bi bi-tag me-1"></i>Ürün Adı
                        </label>
                        <input type="text" name="Name" class="form-control form-control-lg" 
                               value="@Model.Name" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">
                            <i class="bi bi-currency-dollar me-1"></i>Fiyat
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">₺</span>
                            <input type="number" step="0.01" name="Price" class="form-control form-control-lg" 
                                   value="@Model.Price.ToString("F2")" required />
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning btn-lg">
                            <i class="bi bi-check-circle me-2"></i>Güncelle
                        </button>
                        <a href="/Products" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Listeye Dön
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>